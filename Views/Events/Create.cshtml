@model Eventual.Models.Events
@{
var minDate = DateTime.Today.ToString("yyyy-MM-dd");
}
<link rel="stylesheet" href="~/css/eventual.css" asp-append-version="true" />

<main class="form-wrapper">
  <form id="urban-form" asp-action="Create" asp-controller="Events" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <!-- INFORMACIÓN BÁSICA -->
    <p class="form-section-label">01 &mdash; Información básica</p>
    <div class="form-card">

      <!-- Nombre -->
      <div class="input-field">
        <i class="material-icons prefix">event</i>
        <input asp-for="Name" id="nombre-evento" type="text" class="validate" maxlength="150" />
        <label asp-for="Name" for="nombre-evento">
          Nombre del evento
          <span class="required-badge">obligatorio</span>
        </label>
        <span asp-validation-for="Name" class="helper-text red-text"></span>
        <span class="helper-text field-note">Máx. 150 caracteres. Sé claro y memorable.</span>
      </div>

      <!-- Descripción -->
      <div class="input-field" style="margin-top:1.75rem;">
        <i class="material-icons prefix">notes</i>
        <textarea asp-for="Description" id="descripcion-evento"
                  class="materialize-textarea validate" data-length="2000"></textarea>
        <label asp-for="Description" for="descripcion-evento">
          Descripción del evento
          <span class="required-badge">obligatorio</span>
        </label>
        <span asp-validation-for="Description" class="helper-text red-text"></span>
        <span class="helper-text field-note">Describe la propuesta, artistas, formato, etc. (mín. 10 caracteres)</span>
      </div>

    </div>

    <!-- LUGAR Y FECHA -->
    <p class="form-section-label">02 &mdash; Lugar y fecha</p>
    <div class="form-card">

      <!-- Ubicación -->
      <div class="input-field">
        <i class="material-icons prefix">place</i>
        <input asp-for="Location" id="ubicacion-evento" type="text" class="validate" />
        <label asp-for="Location" for="ubicacion-evento">
          Ubicación del evento
          <span class="required-badge">obligatorio</span>
        </label>
        <span asp-validation-for="Location" class="helper-text red-text"></span>
        <span class="helper-text field-note">Dirección completa o nombre del venue.</span>
      </div>

      <!-- Fecha -->
      <div class="input-field" style="margin-top:1.75rem;">
        <i class="material-icons prefix">calendar_today</i>
        <input asp-for="EventDate" id="fecha-evento" type="date" class="validate" min="@minDate" />
        <label asp-for="EventDate" for="fecha-evento" class="active">
          Fecha del evento
          <span class="required-badge">obligatorio</span>
        </label>
        <span asp-validation-for="EventDate" class="helper-text red-text"></span>
        <span class="helper-text field-note">Solo se permiten fechas de hoy en adelante.</span>
      </div>

    </div>

    <!-- POSTER -->
    <p class="form-section-label">03 &mdash; Poster del evento</p>
    <div class="form-card">

      <div style="margin-bottom:1rem;">
        <label style="display:block;color:var(--af-text-muted);font-size:.85rem;margin-bottom:.6rem;">
          <i class="material-icons" style="font-size:1rem;vertical-align:middle;margin-right:.3rem;">image</i>
          Seleccionar imagen (JPG, PNG, WEBP, GIF) — campo opcional. Se ajustará a máx. 1200×800 px.
        </label>
        <label for="imagen-file" class="btn waves-effect btn-reset"
               style="cursor:pointer;display:inline-flex;align-items:center;gap:.4rem;">
          <i class="material-icons" style="font-size:18px;">upload</i>
          Subir imagen
        </label>
        <input asp-for="ImageFile" id="imagen-file" type="file"
               accept=".jpg,.jpeg,.png,.webp,.gif"
               style="display:none;" />
        <span asp-validation-for="ImageFile" class="helper-text red-text" style="display:block;margin-top:.4rem;"></span>
        <span id="file-name-label" style="color:var(--af-text-muted);font-size:.82rem;margin-left:.8rem;vertical-align:middle;">
          Ningún archivo seleccionado
        </span>
      </div>

      <!-- Preview en tiempo real -->
      <div id="poster-preview-wrap" style="display:none;margin-top:1rem;">
        <img id="poster-preview"
             src=""
             alt="Preview poster"
             style="max-height:220px;width:100%;object-fit:cover;border-radius:8px;border:1px solid rgba(255,255,255,.15);" />
      </div>
    </div>

    <!-- SUBMIT -->
    <div class="submit-area">
      <button type="submit" class="btn waves-effect btn-submit">
        <i class="material-icons left" style="font-size:17px;">check</i>
        Registrar evento
      </button>
      <a asp-action="Index" asp-controller="Events" class="btn waves-effect btn-reset">
        Cancelar
      </a>
    </div>

  </form>
</main>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
<script>
  // Preview de imagen al seleccionar archivo
  const fileInput   = document.getElementById('imagen-file');
  const previewWrap = document.getElementById('poster-preview-wrap');
  const previewImg  = document.getElementById('poster-preview');
  const fileLabel   = document.getElementById('file-name-label');

  if (fileInput) {
    fileInput.addEventListener('change', function () {
      const file = this.files[0];
      if (file) {
        fileLabel.textContent = file.name;
        const reader = new FileReader();
        reader.onload = function (e) {
          previewImg.src = e.target.result;
          previewWrap.style.display = 'block';
        };
        reader.readAsDataURL(file);
      } else {
        fileLabel.textContent = 'Ningún archivo seleccionado';
        previewWrap.style.display = 'none';
      }
    });
  }
</script>
}
